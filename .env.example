# --- Provedor de LLM ---
# auto       = tenta na ordem de LLM_FALLBACK_ORDER (padrão: anthropic, cursor)
# anthropic  = só API Anthropic do cliente / gateway corporativo
# cursor     = só Cursor SDK (agente local do Cursor)
LLM_PROVIDER=auto
LLM_FALLBACK_ORDER=anthropic,cursor

# --- Cliente: Anthropic direto ou gateway atrás da VPN ---
# Use ANTHROPIC_BASE_URL se a empresa expõe um proxy interno (ex.: LiteLLM, Bedrock proxy)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- CI&T Flow LiteLLM (JWT no lugar da API key; ver README) ---
# FLOW_LITELLM_PROXY=https://flow.ciandt.com/flow-llm-proxy
# FLOW_API_KEY=
# ANTHROPIC_AUTH_TOKEN=   # alternativa ao FLOW_API_KEY (mesmo JWT)
# ANTHROPIC_BASE_URL pode ficar vazio se FLOW_LITELLM_PROXY estiver definido
# ANTHROPIC_MODEL=bedrock/anthropic.claude-4-6-sonnet

# --- Cursor: Claude via Cursor SDK ---
# Chave em https://cursor.com/settings (API / Agents)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# --- Segmentação de fala (latência vs. cortes) — opcional ---
# FRAME_SECONDS=0.4
# SILENCE_TIMEOUT_SECONDS=0.75
# SYSTEM_SILENCE_TIMEOUT_SECONDS=1.15
# MAX_SEGMENT_SECONDS=12
# PREFIX_PADDING_SECONDS=0.45
# SPEECH_HANGOVER_SECONDS=0.4
# SYSTEM_SILENCE_THRESHOLD=0.006

# --- Perfis de voz (Participante A, B, C…) — requer speechbrain ---
# DIARIZATION_ENABLED=true
# DIARIZATION_MIN_SECONDS=2.0
# SPEAKER_MATCH_THRESHOLD=0.72

# --- Assistente de IA (botões na interface) ---
# ASSISTANT_USER_NAME=Camila

# --- Rede corporativa (VPN / proxy) ---
# O cliente HTTP do Anthropic e do Cursor respeitam estas variáveis do SO
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
